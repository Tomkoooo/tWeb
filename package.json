  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "create-template": "node scripts/create-template.mjs",
    "deployments:validate": "node scripts/deployments/validate.mjs",
